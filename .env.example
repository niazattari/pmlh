# Generic SMTP (recommended for production)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# Optional:
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TO=admin@yourdomain.com

# Gmail (alternative). Use a Gmail App Password (2FA required).
# ADMIN_EMAIL=youraddress@gmail.com
# ADMIN_PASSWORD=your_16_char_app_password
