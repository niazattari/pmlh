<%- include('header.ejs') %>

  <div class="container mt-5">
    <form class="row g-3" action="/user/login" method="POST">
      <div class="login-brand" aria-hidden="true">
        <img src="/images/logo.png" alt="PMLH" onerror="this.onerror=null;this.src='/images/pmlh2.png'">
      </div>
      <h1 class="display-6 text-center mb-4">User Login</h1>
      <p class="login-tagline text-center text-muted mb-4">Professional Training & Certifications</p>

      <div class="col-md-6 offset-md-3">
        <label for="email" class="form-label">Email or Username</label>
        <input type="text" name="email" id="email" class="form-control" required>
      </div>

      <div class="col-md-6 offset-md-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" name="password" id="password" class="form-control" required>
      </div>

      <div class="col-12 text-center mt-4">
        <button type="submit" class="btn btn-success">Login</button>
      </div>
    </form>
    <div class="col-md-6 offset-md-3 text-center mt-2">
      <small>
        <a href="/contact-add">New User? Register</a> |
        <a href="/user/forgot-password">Forgot Password?</a>
      </small>
    </div>
    <div class="col-md-6 offset-md-3 text-center mt-2">
      <small>
        <a href="/">Back to Home</a>
      </small>
    </div>
  </div>

  <%- include('footer.ejs') %>

    <style>
      /* =========================================
   User Login – Professional Styling (No HTML changes)
   ========================================= */

      :root {
        --brand: #0d6efd;
        /* primary */
        --brand-dark: #0b5ed7;
        --accent: #20c997;
        /* teal accent */
        --text: #1f2937;
        /* slate-800 */
        --muted: #6b7280;
        /* slate-500 */
        --bg: #f7f9fc;
        --surface: #ffffff;
        --border: #e5e7eb;
        /* slate-200 */
        --radius: 16px;
        --shadow: 0 12px 30px rgba(16, 24, 40, .12);
      }

      /* Soft background with subtle gradient accents */
      body {
        color: var(--text);
        background:
          radial-gradient(1100px 520px at 10% -10%, rgba(13, 110, 253, .06), transparent 40%),
          radial-gradient(900px 420px at 90% -10%, rgba(32, 201, 151, .06), transparent 35%),
          var(--bg);
        -webkit-font-smoothing: antialiased;
        font-smooth: antialiased;
      }

      /* Narrower content width for focus */
      .container.mt-5 {
        max-width: 960px;
      }

      /* Center and card-ize the form (works with current grid) */
      .container.mt-5 form[action="/user/login"] {
        position: relative;
        max-width: 700px;
        margin: 0 auto;
        padding: 6.25rem 1.5rem 1.75rem;
        background: linear-gradient(180deg, #fff, #fbfbfc 55%, #f8fafc);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      /* Top circular brand badge */
      .login-brand {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: #ffffff;
        border: 4px solid #ffffff;
        display: grid;
        place-items: center;
        box-shadow: 0 14px 34px rgba(16, 24, 40, .18);
      }
      .login-brand img {
        width: 78%;
        height: 78%;
        object-fit: contain;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,.12));
      }

      .login-tagline { font-weight: 500; }

      /* Title styling */
      .container.mt-5 .display-6 {
        font-weight: 700;
        letter-spacing: .2px;
        margin-top: .25rem;
        margin-bottom: .75rem !important;
      }

      /* Labels & controls */
      .container.mt-5 .form-label {
        font-weight: 600;
        color: #111827;
      }

      .container.mt-5 .form-control {
        height: 46px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        transition: border-color .2s ease, box-shadow .2s ease, background-color .2s ease;
      }

      .container.mt-5 .form-control::placeholder {
        color: #9ca3af;
      }

      .container.mt-5 .form-control:focus {
        border-color: var(--brand);
        box-shadow: 0 0 0 .2rem rgba(13, 110, 253, .15);
        outline: none;
      }

      /* Submit button – polished primary */
      .container.mt-5 .btn.btn-success {
        min-height: 46px;
        padding: .6rem 1.25rem;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        letter-spacing: .2px;
        background: linear-gradient(180deg, var(--accent), #18b892);
        box-shadow: 0 10px 24px rgba(32, 201, 151, .22);
        transition: transform .08s ease, box-shadow .2s ease, filter .2s ease;
      }

      .container.mt-5 .btn.btn-success:hover {
        transform: translateY(-1px);
        filter: brightness(1.05);
        box-shadow: 0 14px 30px rgba(32, 201, 151, .26);
      }

      .container.mt-5 .btn.btn-success:active {
        transform: translateY(0);
        box-shadow: 0 8px 18px rgba(32, 201, 151, .2);
      }

      /* Links area under the form – keep centered and tidy */
      .container.mt-5 .col-md-6.offset-md-3.text-center.mt-2 {
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      .container.mt-5 small a {
        color: var(--brand);
        text-decoration: none;
        font-weight: 600;
      }

      .container.mt-5 small a:hover {
        text-decoration: underline;
      }

      /* Focus ring for keyboard accessibility */
      a:focus,
      button:focus,
      input:focus {
        outline: 2px solid rgba(13, 110, 253, .3);
        outline-offset: 2px;
      }

      /* Better mobile spacing */
      @media (max-width: 576px) {
        .container.mt-5 form[action="/user/login"] {
          padding: 1.25rem;
          border-radius: 14px;
        }
        .login-brand {
          width: 80px;
          height: 80px;
          border-width: 3px;
        }
      }

      /* Dark mode support (automatic via OS preference) */
      @media (prefers-color-scheme: dark) {
        :root {
          --text: #e5e7eb;
          --muted: #a1a1aa;
          --bg: #0b1220;
          --surface: #0f172a;
          --border: #1f2937;
          --shadow: 0 12px 30px rgba(0, 0, 0, .38);
        }

        body {
          background:
            radial-gradient(1100px 520px at 10% -10%, rgba(13, 110, 253, .18), transparent 40%),
            radial-gradient(900px 420px at 90% -10%, rgba(32, 201, 151, .18), transparent 35%),
            var(--bg);
        }

        .container.mt-5 form[action="/user/login"] {
          background: linear-gradient(180deg, var(--surface), #0d1730 55%, #0a1328);
          border-color: var(--border);
        }

        .container.mt-5 .form-control {
          background: #0b1324;
          color: var(--text);
          border-color: var(--border);
        }

        .container.mt-5 small a {
          color: #7cc1ff;
        }

        .login-brand {
          background: #0b1324;
          border-color: var(--border);
          box-shadow: 0 14px 34px rgba(0,0,0,.45);
        }
      }
    </style>