<%- include('header') %>

  <div id="main-content">
    <div class="container">
      <div class="row">

        <!-- Left: Course Details (8 columns) -->
        <div class="col-lg-8 col-md-12">
          <!-- post-container -->
          <div class="post-container">
            <div class="post-content single-post">
              <h3>
                <%= singlePost.title %>
              </h3>

              <div class="post-information">
                <span class="post-tag">
                  <i class="fa fa-tags"></i>
                  <a href="/category/<%= singlePost.category.name %>">
                    <%= singlePost.category.name %>
                  </a>
                </span>
                <span class="post-author">
                  <i class="fa fa-user"></i>
                  <a href="/author/<%= singlePost.user.username %>">
                    <%= singlePost.user.username %>
                  </a>
                </span>
                <span class="post-date">
                  <i class="fa fa-calendar"></i>
                  <%= singlePost.formattedDate %>
                </span>
              </div>

              <div class="single-image-details-card text-center mb-3">
                <img class="single-feature-image-small mb-2" src="/uploads/<%= singlePost.image %>"
                  alt="<%= singlePost.title %>" />

                <ul class="list-group text-left mb-2 course-details-list">
                  <li class="list-group-item"><i class="fa fa-book"></i><span><strong>Name:</strong>
                      <%= singlePost.title %>
                    </span></li>
                  <li class="list-group-item"><i class="fa fa-tags"></i><span><strong>Category:</strong>
                      <%= singlePost.category.name %>
                    </span></li>
                  <li class="list-group-item"><i class="fa fa-user"></i><span><strong>Instructor:</strong>
                      <%= singlePost.user.username %>
                    </span></li>
                  <% if (singlePost.category.name === 'Courses' && singlePost.courseDetails) { %>
                    <li class="list-group-item">
                      <i class="fa fa-clock-o"></i>
                      <span><strong>Duration:</strong> <%= singlePost.courseDetails.duration %></span>
                    </li>
                    <li class="list-group-item">
                      <i class="fa fa-calendar"></i>
                      <span><strong>Start Date:</strong>
                        <%= new Date(singlePost.courseDetails.startDate).toLocaleDateString() %>
                      </span>
                    </li>
                    <li class="list-group-item">
                      <i class="fa fa-signal"></i>
                      <span><strong>Level:</strong> <%= singlePost.courseDetails.level %></span>
                    </li>
                    <li class="list-group-item">
                      <i class="fa fa-desktop"></i>
                      <span><strong>Mode:</strong> <%= singlePost.courseDetails.mode %></span>
                    </li>
                    <li class="list-group-item">
                      <i class="fa fa-money"></i>
                      <span><strong>Fee:</strong> <%= singlePost.courseDetails.fee %></span>
                    </li>
                    <li class="list-group-item">
                      <i class="fa fa-language"></i>
                      <span><strong>Language:</strong> <%= singlePost.courseDetails.language %></span>
                    </li>
                    
                   
                    <% if (singlePost.courseDetails.prerequisites?.length > 0) { %>
                      <li class="list-group-item">
                        <i class="fa fa-list"></i>
                        <span><strong>Prerequisites:</strong></span>
                        <ul class="mt-2">
                          <% singlePost.courseDetails.prerequisites.forEach(prereq => { %>
                            <li><%= prereq %></li>
                          <% }) %>
                        </ul>
                      </li>
                    <% } %>
                    <% if (singlePost.courseDetails.syllabusFile) { %>
                      <li class="list-group-item text-center py-3">
                        <a href="/uploads/<%= singlePost.courseDetails.syllabusFile %>" class="btn btn-outline-primary btn-lg" download>
                          <i class="fa fa-download me-1"></i> Download Course Syllabus (PDF)
                        </a>
                      </li>
                    <% } %>
                  <% } %>
                   <!-- Add Registration Button -->
                    <li class="list-group-item text-center py-4">
                      <% if (locals.user) { %>
                        <a href="/course/course-registration/<%= singlePost._id %>" class="btn btn-success btn-lg">
                          Register for this Course
                        </a>
                      <% } else { %>
                        <div class="alert alert-warning">
                          <i class="fa fa-info-circle me-2"></i>
                          Please <a href="/login?redirect=/course/<%= singlePost._id %>" class="text-primary">login</a> to register
                        </div>
                      <% } %>
                    </li>
                </ul>
              </div>

              <p class="description">
                <%= singlePost.description %>
              </p>
            </div>
          </div>
          <!-- Comment Form -->
          <div class="comment-form mt-5 p-4 bg-light rounded shadow-sm">
            <% if (user) { %> <!-- user passed from backend -->
              <h5 class="mb-4">
                <i class="fa fa-pencil-square-o me-2 text-primary"></i> Leave a Comment
              </h5>

              <form action="/site/single/<%= singlePost._id %>" method="POST" autocomplete="off">
                <input type="hidden" name="postId" value="<%= singlePost._id %>">

                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label"><i class="fa fa-user-o me-1"></i> Name</label>
                    <input type="text" name="name" class="form-control" value="<%= user.username %>" readonly>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label"><i class="fa fa-envelope-o me-1"></i> Email</label>
                    <input type="email" name="email" class="form-control" value="<%= user.email %>" readonly>
                  </div>
                  <div class="col-12">
                    <label class="form-label"><i class="fa fa-commenting-o me-1"></i> Comment</label>
                    <textarea name="description" class="form-control" rows="5" placeholder="Write your comment here..." required></textarea>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Rating</label>
                    <select name="rating" class="form-select">
                      <option value="">Rate</option>
                      <option value="5">5 - Excellent</option>
                      <option value="4">4 - Good</option>
                      <option value="3">3 - Average</option>
                      <option value="2">2 - Poor</option>
                      <option value="1">1 - Terrible</option>
                    </select>
                  </div>
                  <div class="col-12 text-end">
                    <button type="submit" class="btn btn-primary">
                      <i class="fa fa-paper-plane me-1"></i> Submit Comment
                    </button>
                  </div>
                </div>
              </form>
            <% } else { %>
              <div class="alert alert-warning text-center">
                <i class="fa fa-exclamation-circle"></i>
                You must <a href="/login" class="text-primary fw-bold">Login</a> or
                <a href="/contact-add" class="text-success fw-bold">Register</a> first to submit a comment.
              </div>
            <% } %>
          </div>

           <!-- Comment Section -->
          <div class="comment-container mt-5">
            <h4 class="mb-4 text-primary">
              <i class="fa fa-comments-o me-2"></i> Comments
            </h4>

            <% if (singlePost?.comment?.length) { %>
              <% singlePost.comment.forEach(comment=> { %>
                <div class="card mb-3 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                      <% if (comment.userImage) { %>
                        <img src="/uploads/<%= comment.userImage %>" alt="avatar" style="width:40px;height:40px;object-fit:cover;border-radius:50%;" class="me-2" />
                      <% } else { %>
                        <i class="fa fa-user-circle fa-lg text-secondary me-2"></i>
                      <% } %>
                      <h6 class="mb-0">
                        <%= comment.name %>
                      </h6>
                      <% if (comment.rating) { %>
                        <span class="ms-3" aria-label="Rating: <%= comment.rating %> out of 5">
                          <% for (var i = 0; i < (comment.rating || 0); i++) { %>
                            <i class="fa fa-star text-warning"></i>
                          <% } %>
                          <% for (var j = (comment.rating || 0); j < 5; j++) { %>
                            <i class="fa fa-star-o text-warning"></i>
                          <% } %>
                        </span>
                      <% } %>
                      <small class="text-muted ms-auto">
                        <i class="fa fa-calendar me-1"></i>
                        <%= new Date(comment.date).toLocaleString() %>
                      </small>
                    </div>
                    <p class="mb-0 text-muted">
                      <%= comment.description %>
                    </p>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted">No comments yet. Be the first to comment!</p>
            <% } %>
          </div>

        </div>
        <%- include('sidebar') %>
      </div>
    </div>
  </div>

  <%- include('footer') %>

  
    <style>
      /* ===========================================
   PMLH – Single Course/Post Styling
   Scoped to #main-content and .post-container
   Author: Niaz x Copilot
=========================================== */
      :root {
        --sp-primary: #0d6efd;
        /* brand primary */
        --sp-accent: #845ef7;
        /* education accent */
        --sp-ink: #0b132b;
        /* headlines / strong text */
        --sp-muted: #6b7280;
        /* muted text */
        --sp-ring: rgba(13, 110, 253, .22);
        /* focus ring */
      }

      /* Page container spacing & subtle backdrop */
      #main-content {
        padding: clamp(20px, 4vw, 28px) 0;
        background:
          radial-gradient(900px 500px at 92% -10%, rgba(13, 110, 253, .06) 0%, transparent 60%),
          radial-gradient(800px 400px at -10% 110%, rgba(132, 94, 247, .06) 0%, transparent 70%),
          #f8f9fa;
      }

      /* ---------- Post wrapper ---------- */
      .post-container {
        background: #fff;
        border: 1px solid rgba(0, 0, 0, .06);
        border-radius: 16px;
        box-shadow: 0 10px 28px rgba(13, 110, 253, .10);
        overflow: hidden;
      }

      /* Content area */
      .post-container .post-content {
        padding: clamp(16px, 2.4vw, 22px);
      }

      /* ---------- Title ---------- */
      .post-container .single-post h3 {
        color: var(--sp-ink);
        font-weight: 800;
        line-height: 1.18;
        margin: 0 0 .75rem 0;
      }

      .post-container .single-post h3::after {
        content: "";
        display: block;
        height: 4px;
        width: 120px;
        margin: .5rem 0 0 0;
        border-radius: 8px;
        background: linear-gradient(90deg, var(--sp-primary), var(--sp-accent));
        opacity: .9;
      }

      /* ---------- Meta information (tags/author/date) ---------- */
      .post-information {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem .75rem;
        margin-bottom: 1rem;
      }

      .post-information>span {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #334155;
        font-weight: 600;
        font-size: .88rem;
        padding: .35rem .6rem;
        border-radius: 999px;
      }

      .post-information i {
        color: var(--sp-primary);
      }

      .post-information a {
        color: inherit;
        text-decoration: none;
        transition: color .15s ease;
      }

      .post-information a:hover {
        color: var(--sp-primary);
      }

      /* ---------- Feature image card ---------- */
      .single-image-details-card {
        background: #fff;
        border: 1px solid rgba(0, 0, 0, .06);
        border-radius: 14px;
        padding: clamp(12px, 2vw, 16px);
        box-shadow: 0 8px 22px rgba(13, 110, 253, .08);
      }

      .single-feature-image-small {
        width: 100%;
        max-height: 340px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, .08);
        box-shadow: 0 10px 26px rgba(13, 110, 253, .12);
      }

      /* ---------- Course details list (list-group) ---------- */
      .course-details-list {
        text-align: left !important;
        margin-top: .75rem;
        border: none;
        border-radius: 12px;
        overflow: hidden;
      }

      .course-details-list .list-group-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        border: none;
        border-bottom: 1px solid rgba(0, 0, 0, .06);
        padding: .65rem .75rem;
        background: #fff;
      }

      .course-details-list .list-group-item:last-child {
        border-bottom: none;
      }

      .course-details-list .list-group-item i {
        width: 36px;
        min-width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        font-size: 16px;
        color: #fff;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--sp-primary), var(--sp-accent));
        box-shadow: 0 6px 14px rgba(13, 110, 253, .18);
      }

      .course-details-list .list-group-item span {
        color: #334155;
        font-weight: 600;
      }

      .course-details-list .list-group-item strong {
        color: var(--sp-ink);
      }

      /* Prerequisites nested list */
      .course-details-list .list-group-item ul {
        margin: .4rem 0 0 0;
        padding-left: 1.2rem;
      }

      .course-details-list .list-group-item ul li {
        color: #475569;
        margin-bottom: .2rem;
        position: relative;
      }

      .course-details-list .list-group-item ul li::marker {
        color: var(--sp-primary);
      }

      /* ---------- Register button & alert ---------- */
      .course-details-list .list-group-item.text-center {
        background: #f9fbff;
      }

      .course-details-list .btn.btn-success {
        border: 1px solid #16a34a;
        border-radius: 999px;
        padding: .7rem 1.1rem;
        font-weight: 800;
        letter-spacing: .2px;
        background: linear-gradient(180deg, #22c55e, #16a34a);
        box-shadow: 0 10px 22px rgba(34, 197, 94, .22);
        transition: transform .08s ease, box-shadow .18s ease, filter .18s ease;
      }

      .course-details-list .btn.btn-success:hover {
        filter: brightness(1.05);
        transform: translateY(-1px);
        box-shadow: 0 12px 26px rgba(34, 197, 94, .30);
      }

      /* Login alert */
      .course-details-list .alert.alert-warning {
        border-radius: 12px;
        border: 1px solid #fde68a;
        background: #fffbeb;
        color: #7c2d12;
        box-shadow: 0 6px 16px rgba(253, 230, 138, .35);
      }

      .course-details-list .alert a.text-primary {
        font-weight: 700;
        text-decoration: underline;
      }

      /* ---------- Description ---------- */
      .post-container .description {
        color: #1f2937;
        font-size: 1.08rem;
        line-height: 1.85;
        margin-top: 1rem;
        background: #ffffff;
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        box-shadow: 0 8px 22px rgba(13,110,253,.08);
      }
      .post-container .description::first-letter{
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        color: #0d6efd;
      }

      /* (instructor passport moved to right sidebar) */

      /* ---------- Links & focus states ---------- */
      .post-container a:focus-visible {
        outline: none;
        box-shadow: 0 0 0 .22rem var(--sp-ring);
        border-radius: 8px;
      }

      /* ---------- Responsive ---------- */
      @media (max-width: 991px) {
        .single-feature-image-small {
          max-height: 280px;
        }
        /* (no floating image inside description on mobile) */
      }

      @media (max-width: 576px) {
        .post-information {
          gap: .45rem .55rem;
        }

        .course-details-list .list-group-item i {
          width: 32px;
          min-width: 32px;
          height: 32px;
          font-size: 15px;
        }
      }

      /* ---------- Optional Dark Mode ---------- */
      @media (prefers-color-scheme: dark) {
        :root {
          --sp-ink: #e9edf5;
          --sp-muted: #9aa4b3;
          --sp-ring: rgba(102, 163, 255, .28);
        }

        #main-content {
          background: linear-gradient(135deg, #0b0e1a 0%, #0f1320 100%);
        }

        .post-container {
          background: #0f1320;
          border-color: rgba(255, 255, 255, .10);
          box-shadow: 0 12px 26px rgba(0, 0, 0, .45);
        }

        .post-container .single-post h3 {
          color: #e9edf5;
        }

        .post-information>span {
          background: #121a2b;
          border-color: rgba(255, 255, 255, .12);
          color: #cfe3ff;
        }

        .single-image-details-card {
          background: #0f1320;
          border-color: rgba(255, 255, 255, .10);
        }

        .single-feature-image-small {
          border-color: rgba(255, 255, 255, .12);
          box-shadow: 0 10px 26px rgba(0, 0, 0, .55);
        }

        .course-details-list .list-group-item {
          background: #0f1320;
          border-bottom-color: rgba(255, 255, 255, .10);
        }

        .course-details-list .list-group-item span {
          color: #cfe3ff;
        }

        .post-container .description {
          color: #cfe3ff;
        }

        /* (instructor passport styles handled in sidebar) */

        .course-details-list .alert.alert-warning {
          background: #3b2f19;
          color: #ffedd5;
          border-color: #fde68a;
        }
      }
      
/* ===========================================
   PMLH – Comments & Comment Form Styling
   Scoped to .comment-container / .comment-form
   Author: Niaz x Copilot
=========================================== */
:root{
  --cmt-primary: #0d6efd;       /* brand primary */
  --cmt-accent:  #845ef7;       /* education accent */
  --cmt-ink:     #0b132b;       /* headlines / strong text */
  --cmt-muted:   #6b7280;       /* muted text */
  --cmt-ring:    rgba(13,110,253,.22); /* focus ring */
}

/* ---------- Comments Heading ---------- */
.comment-container h4{
  font-weight: 800;
  color: var(--cmt-primary) !important;
  letter-spacing: .2px;
  display: inline-flex; align-items: center; gap: .5rem;
  margin-bottom: 1rem !important;
}
.comment-container h4::after{
  content:"";
  display:block; height:4px; width:120px; margin-left:.6rem;
  border-radius:8px;
  background: linear-gradient(90deg, var(--cmt-primary), var(--cmt-accent));
  opacity:.9;
}

/* ---------- Individual Comment Card ---------- */
.comment-container .card{
  border: 1px solid rgba(0,0,0,.06);
  border-radius: 14px;
  box-shadow: 0 6px 22px rgba(13,110,253,.08);
  transition: transform .18s ease, box-shadow .22s ease, border-color .22s ease;
  overflow: hidden;
  background: #fff;
  position: relative;
}
.comment-container .card::before{
  /* decorative top accent */
  content:"";
  position:absolute; inset:0 auto auto 0;
  height: 4px; width: 110px; border-radius:0 0 8px 0;
  background: linear-gradient(90deg, var(--cmt-primary), var(--cmt-accent));
  opacity:.9;
}
.comment-container .card:hover{
  transform: translateY(-2px);
  border-color: #e9efff;
  box-shadow: 0 12px 26px rgba(13,110,253,.14);
}

/* Comment body layout */
.comment-container .card-body{
  padding: 14px 16px;
}

/* Row with avatar, name & date */
.comment-container .card-body .d-flex{
  gap: .6rem;
}

/* Avatar icon: circular gradient badge */
.comment-container .fa-user-circle{
  display:inline-grid; place-items:center;
  width: 38px; height: 38px;
  color:#fff !important; /* icon color */
  border-radius: 50%;
  background: linear-gradient(135deg, var(--cmt-primary), var(--cmt-accent));
  box-shadow: 0 8px 18px rgba(13,110,253,.18);
  position: relative;
}
.comment-container .fa-user-circle::after{
  content:"";
  position:absolute; inset:-3px; border-radius:inherit;
  background: conic-gradient(from 210deg, var(--cmt-primary), var(--cmt-accent), var(--cmt-primary));
  filter: blur(6px); opacity:.28; z-index:-1;
}

/* Name */
.comment-container h6{
  font-weight: 800;
  color: var(--cmt-ink);
}

/* Date pill */
.comment-container small.text-muted{
  background:#f1f5f9;
  border: 1px solid #e2e8f0;
  color:#334155 !important;
  border-radius: 999px;
  padding: .25rem .6rem;
  display: inline-flex; align-items:center; gap:.35rem;
  font-weight: 600;
}

/* Comment text */
.comment-container p.text-muted{
  color:#475569 !important;
  line-height: 1.65;
  margin-top: .35rem;
}

/* Empty state text */
.comment-container p.text-muted:only-child{
  text-align: left;
}

/* ---------- Comment Form Card ---------- */
.comment-form{
  background:#fff !important;
  border: 1px solid rgba(0,0,0,.06);
  border-radius: 16px;
  box-shadow: 0 10px 26px rgba(13,110,253,.10);
  padding: clamp(16px, 2.4vw, 22px) !important;
}

/* Form heading */
.comment-form h5{
  font-weight: 800;
  color: var(--cmt-ink);
  display: inline-flex; align-items:center; gap:.5rem;
  margin-bottom: .75rem !important;
}
.comment-form h5::after{
  content:"";
  display:block; height:3px; width:90px; margin-left:.5rem;
  border-radius:6px;
  background: linear-gradient(90deg, var(--cmt-primary), var(--cmt-accent));
  opacity:.85;
}

/* Labels */
.comment-form .form-label{
  font-weight: 700; color: var(--cmt-ink);
  display:flex; align-items:center; gap:.5rem;
  margin-bottom: .35rem;
}
.comment-form .form-label i{ color: var(--cmt-primary); }

/* Inputs / textarea */
.comment-form .form-control{
  border: 1px solid rgba(0,0,0,.12);
  border-radius: 12px;
  padding: .6rem .75rem;
  background:#fff;
  color:#111827;
  transition: border-color .15s ease, box-shadow .15s ease, background-color .15s ease;
}
.comment-form .form-control::placeholder{ color:#8b97a5; }
.comment-form textarea.form-control{ min-height: 140px; resize: vertical; }

/* Focus & read-only styles */
.comment-form .form-control:focus{
  outline: none;
  border-color: var(--cmt-primary);
  box-shadow: 0 0 0 .22rem var(--cmt-ring);
  background:#fcfdff;
}
.comment-form .form-control[readonly]{
  background:#f8fafc;
  color:#334155;
}

/* Submit button */
.comment-form .btn.btn-primary{
  border: 1px solid #2e7bff;
  border-radius: 999px;
  padding: .6rem 1rem;
  font-weight: 800;
  letter-spacing: .2px;
  background: linear-gradient(180deg, #2e7bff, var(--cmt-primary));
  box-shadow: 0 8px 18px rgba(13,110,253,.20);
  transition: transform .08s ease, box-shadow .18s ease, filter .18s ease;
}
.comment-form .btn.btn-primary:hover{
  filter: brightness(1.05);
  transform: translateY(-1px);
  box-shadow: 0 12px 26px rgba(13,110,253,.28);
}

/* Alert styling (login/register prompt) */
.comment-form .alert.alert-warning{
  border-radius: 12px;
  border: 1px solid #fde68a;
  background: #fffbeb;
  color: #7c2d12;
  box-shadow: 0 6px 16px rgba(253,230,138,.35);
}
.comment-form .alert .text-primary,
.comment-form .alert .text-success{
  font-weight: 700;
  text-decoration: underline;
}

/* ---------- Accessibility: focus-visible for links ---------- */
.comment-container a:focus-visible,
.comment-form a:focus-visible,
.comment-form .btn:focus-visible{
  outline: none;
  box-shadow: 0 0 0 .22rem var(--cmt-ring);
  border-radius: 10px;
}

/* ---------- Responsive tweaks ---------- */
@media (max-width: 576px){
  .comment-container .fa-user-circle{
    width: 34px; height: 34px;
  }
  .comment-container small.text-muted{
    padding: .2rem .5rem;
  }
