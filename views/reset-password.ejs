<%- include('header.ejs') %>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h3 class="mb-3 text-center">Reset Password</h3>
          <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-warning"><%= message %></div>
          <% } %>
          <form action="/user/reset-password" method="POST" autocomplete="off">
            <input type="hidden" name="token" value="<%= token || '' %>">
            <div class="mb-3">
              <label class="form-label">Verification Code</label>
              <input type="text" name="code" class="form-control" pattern="^[0-9]{6}$" placeholder="6-digit code" required>
            </div>
            <div class="mb-3">
              <label class="form-label">New Password</label>
              <input type="password" name="password" class="form-control" minlength="8" placeholder="At least 8 characters" required>
            </div>
            <div class="text-center">
              <button type="submit" class="btn btn-success">Update Password</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('footer.ejs') %>
