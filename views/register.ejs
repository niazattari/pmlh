<%- include('header.ejs', { limitedHeader: true }) %>

<style>
  /* Page-specific improvements for register page */
  .register-hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 0;
  }

  .register-card {
    max-width: 820px;
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    overflow: hidden;
  }

  .register-card .card-body { padding: 28px; }
  .form-label { font-weight:600; }
  .btn-primary { background: #0d6efd; border: none; }
  .form-control:focus { box-shadow: 0 0 0 0.1rem rgba(13,110,253,.15); }
</style>

<section class="register-hero">
  <div class="card register-card">
    <div class="row g-0">
      <div class="col-md-6 d-none d-md-block" style="background: url('/assets/images/pmlh logo.png') center/contain no-repeat; background-color:#f7f9fc; min-height:300px;">
        <!-- Decorative side: logo / illustration -->
      </div>
      <div class="col-md-6">
        <div class="card-body">
          <h2 class="card-title text-center mb-3">Create a New Record</h2>
          <p class="text-muted text-center small mb-4">Fill the details below. We'll keep your data safe.</p>

          <form id="myForm" class="row g-3" action="/register" method="post" enctype="multipart/form-data">
            <div class="col-md-6">
              <label for="name" class="form-label">Name</label>
              <input type="text" name="name" id="name" class="form-control" required placeholder="Your full name" pattern="^[A-Za-z\s]{2,100}$" title="Use letters and spaces only">
            </div>

            <div class="col-md-6">
              <label for="fatherName" class="form-label">Father Name</label>
              <input type="text" name="fatherName" id="fatherName" class="form-control" required placeholder="Father name" pattern="^[A-Za-z\s]{2,100}$" title="Use letters and spaces only">
            </div>

            <div class="col-md-6">
              <label for="contactNo" class="form-label">Contact No</label>
              <input type="text" name="contactNo" id="contactNo" class="form-control" placeholder="03xx-xxxxxxx" pattern="^03[0-9]{2}-?[0-9]{7}$" title="Use format 03xx-xxxxxxx">
            </div>

            <div class="col-md-6">
              <label for="email" class="form-label">Email</label>
              <input type="email" name="email" id="email" class="form-control" placeholder="you@example.com" required>
              <div id="emailHelp" class="form-text small text-danger" style="display:none;"></div>
            </div>

            <div class="col-md-6">
              <label for="password" class="form-label">Password</label>
              <input type="password" name="password" id="password" class="form-control" placeholder="Choose a password" pattern="(?=.{8,})" title="Minimum 8 characters">
            </div>

            <div class="col-md-6">
              <label for="country" class="form-label">Country</label>
              <input type="text" name="country" id="country" class="form-control" placeholder="Country" pattern="^[A-Za-z\s]{2,56}$" title="Use letters and spaces only">
            </div>

            <div class="col-12">
              <label for="address" class="form-label">Address</label>
              <input type="text" name="address" id="address" class="form-control" placeholder="Street, City" pattern="^.{5,200}$" title="Enter a valid address (min 5 characters)">
            </div>

            <div class="col-12">
              <label class="form-label">Course</label>
              <select name="CourseId" class="form-select">
                <% Post.forEach(category => { %>
                <option value="<%= category._id %>"><%= category.name %></option>
                <% }); %>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label">Profile Photo</label>
              <div class="d-flex align-items-center gap-3">
                <img id="profilePreview" src="/images/user.png" alt="Preview" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:1px solid rgba(0,0,0,.1);">
                <input type="file" name="image" id="profileImage" class="form-control" required accept="image/*">
              </div>
              <small class="text-muted">Square images look best. Max ~2MB recommended.</small>
            </div>

            <div class="col-12 text-center mt-3">
              <button type="submit" class="btn btn-primary btn-lg me-2">Submit</button>
              <button type="button" class="btn btn-outline-danger btn-lg" onclick="window.location.href='/'">Cancel</button>
            </div>
          </form>
          <div class="text-center mt-3">
            <small id="loginLink" style="display:none;">Already registered? <a href="/user/login">Login here</a></small>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('footer.ejs') %>

<script>
// Client-side email existence check
document.addEventListener('DOMContentLoaded', function(){
  const emailInput = document.getElementById('email');
  const emailHelp = document.getElementById('emailHelp');
  const loginLink = document.getElementById('loginLink');

  let last = '';
  emailInput && emailInput.addEventListener('blur', async function(){
    const v = emailInput.value.trim();
    if (!v || v === last) return;
    last = v;
    try {
      const res = await fetch('/api/check-email?email=' + encodeURIComponent(v));
      const json = await res.json();
      if (json.exists) {
        emailHelp.style.display = 'block';
        emailHelp.textContent = 'This email is already registered. Please login to access courses.';
        loginLink.style.display = 'block';
      } else {
        emailHelp.style.display = 'none';
        emailHelp.textContent = '';
        loginLink.style.display = 'none';
      }
    } catch (e) {
      console.warn('Email check failed', e);
    }
  });

  // Basic client-side validation before submit
  const form = document.getElementById('myForm');
  form && form.addEventListener('submit', function(e){
    // check patterns
    const phone = document.getElementById('contactNo');
    if (phone && !phone.checkValidity()) {
      e.preventDefault();
      phone.focus();
      return;
    }
    const pwd = document.getElementById('password');
    if (pwd && pwd.value && pwd.value.length < 8) {
      e.preventDefault();
      pwd.focus();
      return;
    }
  });
});
</script>
<script>
// Live preview for profile image
document.addEventListener('DOMContentLoaded', function(){
  const input = document.getElementById('profileImage');
  const preview = document.getElementById('profilePreview');
  if(input && preview){
    input.addEventListener('change', function(){
      const f = this.files && this.files[0];
      if(!f) return;
      const url = URL.createObjectURL(f);
      preview.src = url;
    });
  }
});
</script>