<section class="webinar-section" id="webinar">
  <!-- Header Area -->
  <div class="webinar-header">
    <div class="container">
      <div class="text-center py-5" data-aos="fade-up" data-aos-duration="800">
        
        <span class="badge bg-primary-subtle text-primary mb-2">Knowledge Hub</span>
        <h2 class="display-4 fw-bold text-dark mb-3">Latest Webinars</h2>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">Enhance your professional growth with our curated collection of insightful webinars.</p>
      </div>
    </div>
  </div>

  <!-- Webinars Carousel Area -->
  <div class="webinar-carousel-section py-5">
    <div class="container">
      <% if (typeof webinars !== 'undefined' && webinars && webinars.length > 0) { %>
        <div id="webinarCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% for (let i = 0; i < webinars.length; i += 3) { %>
              <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                <div class="row g-4">
                  <% for(let j = i; j < Math.min(i + 3, webinars.length); j++) { %>
                    <div class="col-md-4">
                      <div class="webinar-card">
                        <div class="ratio ratio-16x9 mb-2">
                          <iframe src="<%= webinars[j].description %>" 
                                  title="<%= webinars[j].title %>"
                                  allowfullscreen 
                                  class="rounded-4">
                          </iframe>
                        </div>
                        <div class="card-content p-4">
                          <h5 class="fw-bold mb-2"><%= webinars[j].title %></h5>
                          <div class="webinar-meta d-flex align-items-center text-muted small">
                            <i class="bi bi-person ms-3 me-2"></i>
                            <span>Professional</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
          
          <!-- Custom Navigation -->
          <div class="carousel-navigation mt-4">
            <button class="nav-button prev" data-bs-target="#webinarCarousel" data-bs-slide="prev">
              <i class="bi bi-arrow-left"></i>
            </button>
            <button class="nav-button next" data-bs-target="#webinarCarousel" data-bs-slide="next">
              <i class="bi bi-arrow-right"></i>
            </button>
          </div>
        </div>
      <% } else { %>
        <div class="text-center py-5">
          <div class="empty-state">
            <i class="bi bi-camera-video display-1 text-muted mb-3"></i>
            <h4>No Webinars Available</h4>
            <p class="text-muted">Check back soon for new content!</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
  .webinar-section {
    background-color: #f8f9fa;
    min-height: 100vh;
  }

  .webinar-header {
    background: linear-gradient(to right, #ffffff, #f1f4f9);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .webinar-brand { display:flex; flex-direction:column; align-items:center; justify-content:center; }
  .webinar-logo { height:64px; filter: drop-shadow(0 2px 6px rgba(0,0,0,.12)); }
  .brand-icons { display:flex; gap:.75rem; margin-top:.5rem; color:#0d6efd; font-size:1.1rem; }
  .brand-icons i { background:#fff; border:1px solid rgba(0,0,0,.06); border-radius:999px; padding:.45rem; box-shadow:0 6px 14px rgba(13,110,253,.10); }

  .webinar-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    height: 100%;
  }

  .webinar-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }

  .carousel-navigation {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .nav-button {
    width: 3.5rem;
    height: 3.5rem;
    border: none;
    border-radius: 50%;
    background: white;
    box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: #0d6efd;
  }

  .nav-button:hover {
    background: #0d6efd;
    color: white;
    transform: translateY(-2px);
  }

  .empty-state {
    padding: 3rem;
    background: white;
    border-radius: 1rem;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .webinar-card {
      margin-bottom: 1.5rem;
    }
  }
</style>

<!-- Add Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">

<script>
document.addEventListener('DOMContentLoaded', function() {
  const categorySelect = document.querySelector('select[name="category"]');
  const courseFields = document.getElementById('courseFields');

  if (categorySelect) {
    categorySelect.addEventListener('change', function() {
      if (this.value.toLowerCase() === 'courses') {
        courseFields.classList.remove('d-none');
      } else {
        courseFields.classList.add('d-none');
      }
    });
  }
});
</script>