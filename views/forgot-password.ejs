<%- include('header.ejs') %>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h3 class="mb-3 text-center">Forgot Password</h3>
          <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-info"><%= message %></div>
          <% } %>
          <form action="/user/forgot-password" method="POST" autocomplete="off">
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" required>
            </div>
            <div class="text-center">
              <button type="submit" class="btn btn-primary">Send Reset Code</button>
            </div>
          </form>
          <% if (typeof devResetLink !== 'undefined' && devResetLink) { %>
            <div class="alert alert-warning mt-3">
              <div><strong>Dev Reset Link:</strong> <a href="<%= devResetLink %>"><%= devResetLink %></a></div>
              <div><strong>Verification Code:</strong> <code><%= devCode %></code></div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('footer.ejs') %>
