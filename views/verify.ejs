<%- include('header') %>

<div class="container mt-5">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <h2 class="m-0">Verify Your Certificate</h2>
    <img src="/images/logo.png" alt="PMLH" style="height:50px; width: 100px" onerror="this.onerror=null;this.src='/images/pmlh2.png'">
  </div>
  <p class="text-muted">Enter your name and email to verify your certificate.</p>

  <!-- Search Form -->
  <form action="/user/verify" method="post" class="mb-4" aria-label="Certificate verification form">
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Certificate Number <span class="text-danger">*</span></label>
        <input type="text" name="certificateNumber" class="form-control" placeholder="e.g., PMLH-2025-ABCD" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" placeholder="e.g., John Doe">
      </div>
      <div class="col-md-4">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="e.g., john@example.com">
      </div>
            <div class="col-md-2 mt-2">
        <button class="btn btn-primary w-100" type="submit"><i class="fa fa-search me-1"></i> Verify</button>
      </div>
    </div>
  </form>

  <% if (certificate) { %>
    <div class="card p-4 shadow-lg">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="m-0">Certificate Details</h4>
        <span class="badge bg-success-subtle text-success border"><i class="fa fa-check-circle me-1"></i> Verified</span>
      </div>

      <div class="row">
        <!-- Certificate Info -->
        <div class="col-md-6">
          <p><strong>Name:</strong> <%= certificate.name %></p>
          <p><strong>Email:</strong> <%= certificate.email %></p>
          <p><strong>Batch No:</strong> <%= certificate.batchNo || '-' %></p>
          <p><strong>Certificate #:</strong> <span class="badge-inline"><%= certificate.certificateNumber %></span></p>
          <p><strong>Date of Completion:</strong> 
            <%= certificate.dateOfCompletion ? new Date(certificate.dateOfCompletion).toLocaleDateString() : '-' %>
          </p>

          <% if (certificate.user) { %>
            <div class="registered-user d-flex align-items-center mt-3">
              <% if (certificate.user.profileImage) { %>
                <img src="/uploads/<%= certificate.user.profileImage %>" alt="Profile"
                     class="reg-avatar me-2">
              <% } else { %>
                <span class="reg-avatar placeholder me-2"><i class="fa fa-user"></i></span>
              <% } %>
              <div>
                <div class="fw-bold"><%= certificate.user.username || certificate.user.name || certificate.name %></div>
                <div class="text-muted small"><%= certificate.user.email || certificate.email %></div>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Certificate Preview + Download + QR -->
        <div class="col-md-6 actions-panel text-center">
          <h5>Certificate Preview</h5>

          <% if (certificate.certificateFile) { %>
            <% if (certificate.certificateFile.toLowerCase().endsWith('.pdf')) { %>
              <iframe src="/uploads/<%= certificate.certificateFile %>" class="preview-frame" title="Certificate PDF preview"></iframe>
            <% } else { %>
              <img src="/uploads/<%= certificate.certificateFile %>" class="preview-image" alt="Certificate image preview">
            <% } %>

            <div class="actions-grid mt-3">
              <% if (qrCodeDataURL) { %>
                <div class="qr-box">
                  <img src="<%= qrCodeDataURL %>" alt="QR Code">
                </div>
              <% } %>
              <div>
                <a href="/uploads/<%= certificate.certificateFile %>" download class="btn btn-success">
                  <i class="fa fa-download"></i> Download Certificate
                </a>
                <div class="mt-2">
                  <a href="/user/verify-certificate" target="_blank">Verify online</a>
                </div>
              </div>
            </div>
          <% } else { %>
            <p class="text-danger">No certificate file uploaded.</p>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (typeof notFound !== 'undefined' && notFound) { %>
    <div class="alert alert-danger mt-4">
      No matching certificate found. Please check your name and email.
    </div>
  <% } %>
</div>

<%- include('footer') %>

<style>
  
/* ================================
   Certificate Verification UI
   Author: You (Niaz Ali Anjum)
   Notes:
   - Designed to complement Bootstrap
   - Accessible contrast + focus states
   - Responsive previews + print styles
   ================================ */

/* ---------- Theme Variables ---------- */
:root{
  --brand: #0d6efd;        /* Bootstrap Primary */
  --brand-dark: #0b5ed7;
  --accent: #20c997;       /* Teal accent */
  --text: #1f2937;         /* Slate-800 */
  --muted: #6b7280;        /* Slate-500 */
  --bg: #f7f9fc;           /* soft background */
  --surface: #ffffff;
  --border: #e5e7eb;       /* Slate-200 */
  --shadow: 0 8px 24px rgba(16,24,40,.08);
  --radius: 14px;
}

/* ---------- Global ---------- */
html, body {
  height: 100%;
}
body {
  color: var(--text);
  background:
    radial-gradient(1200px 600px at 10% -10%, rgba(13,110,253,.06), transparent 40%),
    radial-gradient(800px 400px at 90% -10%, rgba(32,201,151,.06), transparent 35%),
    var(--bg);
  font-smooth: antialiased;
  -webkit-font-smoothing: antialiased;
}

.container.mt-5 {
  max-width: 1000px;
}
.mt-5{ 
margin-top: 5rem !important;
}
/* ---------- Page Header ---------- */
.container.mt-5 > h2 {
  font-weight: 700;
  letter-spacing: .2px;
  margin-bottom: .25rem;
}

.container.mt-5 > p.text-muted {
  color: var(--muted) !important;
  margin-bottom: 1.5rem;
}

/* ---------- Form ---------- */
form[action="/user/verify"] {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  box-shadow: var(--shadow);
}

form[action="/user/verify"] .form-control {
  height: 46px;
  border-radius: 10px;
  border-color: var(--border);
  transition: border-color .2s ease, box-shadow .2s ease;
}

form[action="/user/verify"] .form-control:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
  outline: none;
}

form[action="/user/verify"] .btn.btn-primary {
  height: 46px;
  border-radius: 10px;
  background: linear-gradient(180deg, var(--brand), var(--brand-dark));
  border: none;
  font-weight: 600;
  letter-spacing: .2px;
  box-shadow: 0 6px 18px rgba(13,110,253,.25);
  transition: transform .08s ease, box-shadow .2s ease;
}

form[action="/user/verify"] .btn.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(13,110,253,.28);
}

form[action="/user/verify"] .btn.btn-primary:active {
  transform: translateY(0);
  box-shadow: 0 4px 12px rgba(13,110,253,.2);
}

/* ---------- Certificate Card ---------- */
.card.p-4.shadow-lg {
  border-radius: 18px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  background: linear-gradient(180deg, #fff, #fbfbfc 55%, #f8fafc);
}

.card .mb-3 {
  margin-bottom: 1rem !important;
}

.card h4 {
  font-weight: 700;
  margin-bottom: 1rem;
  position: relative;
}
.card h4::after {
  content: "";
  display: block;
  width: 64px;
  height: 3px;
  border-radius: 2px;
  margin-top: .4rem;
  background: linear-gradient(90deg, var(--brand), var(--accent));
}

/* ---------- Certificate Info ---------- */
.card .col-md-6 p {
  margin-bottom: .5rem;
}

.card .col-md-6 p strong {
  min-width: 170px;
  display: inline-block;
  color: #111827; /* Slate-900 */
}

.badge-inline {
  display: inline-block;
  font-size: .85rem;
  padding: .25rem .5rem;
  border-radius: 6px;
  background: #eef2ff; /* indigo-50 */
  color: #3730a3;      /* indigo-700 */
  border: 1px solid #e0e7ff;
}

/* ---------- Preview Section ---------- */
.col-md-6.text-center h5 {
  font-weight: 600;
  margin-bottom: .75rem;
}

/* Normalize iframe & image attributes if set inline */
.col-md-6.text-center iframe,
.col-md-6.text-center img {
  border: 1px solid var(--border) !important;
  border-radius: 12px;
  box-shadow: var(--shadow);
}

/* Responsive preview: iframe (PDF) */
.preview-frame,
.col-md-6.text-center iframe {
  width: 100% !important;
  max-width: 520px;
  aspect-ratio: 5 / 7;     /* portrait-ish */
  height: auto !important;
  background: #fafafa;
}

/* Responsive preview: image */
.preview-image,
.col-md-6.text-center img {
  width: 100%;
  max-width: 520px;
  max-height: 400px;
  object-fit: contain;
  background: #fafafa;
}

/* ---------- Action Buttons ---------- */
.btn-success {
  border-radius: 10px;
  font-weight: 600;
  letter-spacing: .2px;
  box-shadow: 0 8px 22px rgba(32,201,151,.22);
  border: none;
  background: linear-gradient(180deg, var(--accent), #18b892);
}
.btn-success:hover {
  filter: brightness(1.05);
  transform: translateY(-1px);
}
.btn-success i {
  margin-right: .4rem;
}

/* ---------- QR Code ---------- */
.qr-box {
  display: inline-flex;
  align-items: center;
  gap: .75rem;
  padding: .75rem;
  border: 1px dashed #cbd5e1;
  border-radius: 12px;
  background: #f8fafc;
}
.qr-box img {
  width: 150px;
  height: 150px;
  border-radius: 8px;
}

/* ---------- Verification Link ---------- */
.col-md-6.text-center a[target="_blank"] {
  font-weight: 600;
  color: var(--brand);
  text-decoration: none;
}
.col-md-6.text-center a[target="_blank"]:hover {
  text-decoration: underline;
}

/* ---------- Alerts ---------- */
.alert-danger {
  border-radius: 12px;
  border: 1px solid #fecaca;
  background: #fef2f2;
  color: #7f1d1d;
  box-shadow: 0 8px 22px rgba(244,63,94,.14);
}

/* ---------- Footer ---------- */
footer {
  margin-top: 3rem;
  color: var(--muted);
}

/* ---------- Accessibility: Focus Rings ---------- */
a:focus,
button:focus,
input:focus,
textarea:focus {
  outline: 2px solid rgba(13,110,253,.3);
  outline-offset: 2px;
}

/* ---------- Responsive ---------- */
@media (max-width: 768px) {
  .container.mt-5 {
    padding-left: .75rem;
    padding-right: .75rem;
  }
  form[action="/user/verify"] .row.g-2 > [class*="col-"] {
    margin-bottom: .5rem;
  }
  .card .row > [class*="col-"] {
    margin-bottom: 1rem;
  }
}

/* ---------- Print Styles (for saving/printing certificates) ---------- */
@media print {
  body {
    background: #fff !important;
  }
  header, nav, footer, form[action="/user/verify"], .alert {
    display: none !important;
  }
  .container.mt-5 {
    margin: 0;
    width: 100%;
    max-width: none;
    padding: 0;
  }
  .card.p-4.shadow-lg {
    box-shadow: none !important;
    border: none !important;
    padding: 0 !important;
    background: #fff !important;
  }
  .col-md-6.text-center img,
  .col-md-6.text-center iframe {
    max-width: 100% !important;
    width: 100% !important;
    border: none !important;
    box-shadow: none !important;
  }
}

/* ---------- Dark Mode ---------- */
@media (prefers-color-scheme: dark) {
  :root {
    --text: #e5e7eb;
    --muted: #9ca3af;
    --bg: #0b1220;
    --surface: #0f172a;
    --border: #1f2937;
    --shadow: 0 10px 28px rgba(0,0,0,.35);
  }
  body {
    background:
      radial-gradient(1200px 600px at 10% -10%, rgba(13,110,253,.18), transparent 40%),
      radial-gradient(800px 400px at 90% -10%, rgba(32,201,151,.18), transparent 35%),
      var(--bg);
  }
  form[action="/user/verify"] .form-control {
    background: #0b1324;
    color: var(--text);
    border-color: var(--border);
  }
  .alert-danger {
    background: #1b0e0e;
    border-color: #7f1d1d;
    color: #fecaca;
  }
}

/* =========================================
   Compact Preview + Actions in One Pane
   ========================================= */

/* Make the right column content stay visible while reading info on the left */
.actions-panel {
  position: sticky;
  top: 1rem;
  display: grid;
  grid-template-rows: auto auto auto;
  gap: 1rem;
}

/* Smaller certificate preview */
.preview-frame,
.preview-image,
.col-md-6.text-center iframe,
.col-md-6.text-center img {
  width: 100% !important;
  max-width: 320px !important;   /* was 520px */
  max-height: 220px !important;  /* tighter height */
  aspect-ratio: 4 / 5;
  margin: 0 auto;
  object-fit: contain;
}

/* Keep the QR code and Download button together in one visible row on desktop */
.actions-grid {
  display: grid;
  grid-template-columns: 160px 1fr;   /* QR left, button right */
  align-items: center;
  gap: 1rem;
}

/* QR box stays compact */
.qr-box {
  padding: .5rem;
}
.qr-box img {
  width: 150px;
  height: 150px;
}

/* Make the download button comfy but not huge */
.actions-grid .btn-success {
  min-height: 44px;
  font-size: 0.95rem;
  width: 100%;
}

/* Subtle heading spacing above preview */
.col-md-6.text-center h5 {
  margin-bottom: .5rem;
}

/* Responsive: stack QR + button on mobile */
@media (max-width: 768px) {
  .actions-grid {
    grid-template-columns: 1fr;
  }
}

/* Print: keep everything in one page if possible */
@media print {
  .card {
    page-break-inside: avoid;
  }
  .actions-grid {
    grid-template-columns: 150px 1fr;
  }
  .preview-frame,
  .preview-image {
    max-width: 260px !important;  /* a bit smaller for page */
    max-height: 180px !important;
  }
}

</style>
<style>
  /* Registered user info styling */
  .registered-user .reg-avatar{
    width: 52px; height: 52px; border-radius: 50%; object-fit: cover;
    border: 1px solid var(--border); box-shadow: var(--shadow);
    background: #fff;
  }
  .registered-user .reg-avatar.placeholder{
    display:inline-grid; place-items:center; color:#64748b; background:#f1f5f9;
  }
</style>