<%-include('header.ejs')%>

    <div class="container-fluid" id="form-myDiv">
        <form action="/admin/contact-view/<%=contactId._id%>" method="post" id="myForm">
             <h1 class="display-6 text-center mb-4">Update Record</h1>
             //draw a table to view contact view details like a table

             table
            <div>
                <label class="col-sm-2 col-form-label" for="name">Name</label>
                <input class="form-control col-6" type="text" name="name" id="name"
                    value="<%=contactId.name%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="fatherName">Father Name</label>
                <input class="form-control col-6" type="text" name="fatherName" id="fatherName"
                    value="<%=contactId.fatherName%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="contactNo">Contact No</label>
                <input class="form-control col-6" type="text" name="contactNo" id="contactNo"
                    value="<%=contactId.contactNo%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="email">Email</label>
                <input class="form-control col-6" type="text" name="email" id="email" value="<%=contactId.email%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="password">Password</label>
                <input class="form-control col-6" type="text" name="password" id="password"
                    value="<%=contactId.password%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="country">Country</label>
                <input class="form-control col-6" type="text" name="country" id="country"
                    value="<%=contactId.country%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="address">Address</label>
                <input class="form-control col-6" type="text" name="address" id="address"
                    value="<%=contactId.address%>">
            </div>
            <div>
                <label class="col-sm-2 col-form-label" for="status">Status</label>
                <input class="form-control col-8" type="text" name="status" id="status"
                    value="<%=contactId.status%>">
            </div>
            <div class="row myButton my-2 ">
                <input class="btn btn-primary col-4" type="submit" value="Submit">
                <input class="btn btn-danger  col-4" type="cancel" value="Cancel" onclick="window.location.href='/admin/contact-list'">
            </div>
        </form>
    </div>
  <%-include('footer.ejs')%>

