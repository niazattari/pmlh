
<%- include('header') %>
  <div id="admin-content">
      <div class="container">
          <div class="row">
              <div class="col-md-10">
                  <h1 class="admin-heading">All Posts</h1>
              </div>
              <div class="col-md-2">
                  <a class="add-new" href="contact-add/addNewUser">add Contact</a>
              </div>
              <div class="col-md-12">
                  <table class="content-table">
                      <thead>
                          <th>S.No.</th>
                          <th>Name</th>
                          <th>Father Name</th>
                          <th>Contact No</th>
                          <th>Email</th>
                          <th>Password</th>
                          <th>Country</th>
                          <th>Address</th>
                          <th>Date</th>
                          <th>Status</th>
                          <th>Edit</th>
                          <th>Delete</th>
                      </thead>
                      <tbody>

                            <% contacts.forEach(function(contact, index){ %>
                                <tr>
                                    <td class='id'><%= offset + index + 1 %></td>
                                    <td><%= contact.title %></td>
                                    <td><%= contact.name %></td>
                                    <td><%= contact.fatherName%></td>
                                    <td><%= contact.address %></td>
                                     
                                    <td><%= contact.formattedDate %></td>
                                    <td>
                                      <img class="w-75" src="<%= post.status ? '/images/green_icon.png': '/images/red_icon1.png' %>" alt="">
                                      </td>
                                      <!-- <img src="images/green_icon.png" alt=""> -->
                                    <td class='edit'><a href='/admin/update-post/<%= contact._id %>'><i class='fa fa-edit'></i></a></td>
                                    <td class='delete'><a href='/admin/delete-post/<%= contact._id %>'><i class='fa fa-trash-o'></i></a></td>
                                </tr>
                            <% }) %>                        
                          
                      </tbody>
                  </table>
                  
                  <ul class='pagination admin-pagination'>
                    <% if (currentPage > 1) { %>
                      <li>
                        <a href="/admin/post?page=<%= currentPage - 1 %>">Previous</a>
                      </li>
                    <% } %>
        
                    <% if (totalPages > 1) { %>
                      <% for (let i=1; i <= totalPages; i++) { %>
                        <li class="<%= currentPage === i ? 'active' : '' %>">
                          <a href="/admin/post?page=<%= i %>">
                            <%= i %>
                          </a>
                        </li>
                      <% } %>
                    <% }  %>
        
                    <% if (currentPage < totalPages) { %>
                      <li><a href="/admin/post?page=<%= currentPage + 1 %>">Next</a></li>
                    <% } %>
                </ul>
              </div>
          </div>
      </div>
  </div>
  <%- include('footer') %>

