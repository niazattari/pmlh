<%- include('header.ejs', { page: 'messages' }) %>
  <link rel="stylesheet" href="/css/contact-list-styles.css">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-offset-1 col-md-10">
        <div class=" panel">
          <div class="panel-heading">
            <div class="row">
              <div class="col-sm-5 col-xs-12">
                <h4 class="title">User Messages <span>List</span></h4>
              </div>
              <div class="col-sm-7 col-xs-12 text-right">
                <div class="btn_group">
                  <span class="label label-danger">Filter:</span>
                  <button type="button" class="btn btn-warning" title="Blocked"><i class="fa fa-ban"></i></button>
                  <button type="button" class="btn btn-success" title="Active"><i
                      class="fa fa-check-square"></i></button>
                </div>
                <a href="/" class="btn add-new" target="_blank"><i class="fa fa-plus-circle"></i>
                  Add New Messages
                </a>
              </div>
            </div>
          </div>
          <div class="panel-body table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Message</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (Array.isArray(messages)) { %>
                  <% if (messages.length===0) { %>
                    <tr>
                      <td colspan="7" class="text-center">No messages found.</td>
                    </tr>
                    <% } %>
                      <%var sno=1%>
                        <%messages.forEach(element=>{%>
                          <tr>
                            <td scope="col">
                              <%=sno++%>
                            </td>

                            <td scope="col">
                              <%=element.name%>
                            </td>
                            <td scope="col">
                              <%=element.email%>
                            </td>
                            <td scope="col">
                              <%=element.message%>
                            </td>
                            <td scope="col">
                              <%=element.date%>
                            </td>
                            <td scope="col">
                              <% if (element.status) { %>
                                <button type="button" class="btn btn-success" title="Active"><i
                                    class="fa fa-check-square"></i></button>
                                <% } else { %>
                                  <button type="button" class="btn btn-warning" title="Blocked"><i
                                      class="fa fa-ban"></i></button>
                                  <% } %>
                            </td>


                            <td>
                              <ul class="action-list">
                                <li><button type="button" class="btn btn-warning"><i class="fa fa-eye"></i></button>
                                </li>
                                <li><a href="/admin/message-update/<%=element._id%>" class="btn btn-primary"><i
                                      class="fa fa-pencil"></i></a>
                                </li>
                                <li><a href="/admin/message-delete/<%=element._id%>" class="btn btn-danger"><i
                                      class="fa fa-trash"></i></a></li>
                              </ul>
                            </td>
                          </tr>
                          <%})%>
                            <% } else { %>
                              <!-- handle the case where messages is not an array -->
                              <p>No messages found.</p>
                              <% } %>

              </tbody>
            </table>
          </div>
          <div class="panel-footer">
            <div class="row">
              <!-- <div class="col col-sm-6 col-xs-8">Showing <b>5</b> out of <b>25</b> entries</div> -->
              <div class="col-sm-12">
                <ul class='pagination admin-pagination'>
                  <% if (currentPage> 1) { %>
                    <li>
                      <a href="/admin/messages?page=<%= currentPage - 1 %>">Previous</a>
                    </li>
                    <% } %>

                      <% if (totalPages> 1) { %>
                        <% for (let i=1; i <=totalPages; i++) { %>
                          <li class="<%= currentPage === i ? 'active' : '' %>">
                            <a href="/admin/messages?page=<%= i %>">
                              <%= i %>
                            </a>
                          </li>
                          <% } %>
                            <% } %>

                              <% if (currentPage < totalPages) { %>
                                <li><a href="/admin/messages?page=<%= currentPage + 1 %>">Next</a>
                                </li>
                                <% } %>
                </ul>
                <ul class="pagination visible-xs">
                  <li><a href="#">
                    </a>
                  </li>
                  <li><a href="#"></a></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%-include('footer.ejs')%>