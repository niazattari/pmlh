<style>
  
/* ===========================================
   PMLH – Contact Section (CSS-only, scoped)
   Author: Niaz x Copilot
=========================================== */
:root{
  --ct-primary: #0d6efd;       /* Brand primary (Bootstrap blue) */
  --ct-accent:  #845ef7;       /* Accent (education purple)      */
  --ct-ink:     #0b132b;       /* Headlines / strong text        */
  --ct-muted:   #6b7280;       /* Muted text                     */
  --ct-success: #22c55e;       /* Success green                  */
  --ct-ring:    rgba(13,110,253,.22); /* Focus ring */
}

/* Section backdrop: subtle gradients + breathing room */
.contact-us{
  position: relative;
  padding: clamp(40px, 6vw, 70px) 0;
  background:
    radial-gradient(900px 500px at 92% -10%, rgba(13,110,253,.06) 0%, transparent 60%),
    radial-gradient(800px 400px at -10% 110%, rgba(132,94,247,.06) 0%, transparent 70%),
    #f8f9fa;
  overflow: hidden;
}
.contact-us::before,
.contact-us::after{
  content:"";
  position:absolute; border-radius:50%; z-index:0; pointer-events:none;
}
.contact-us::before{
  width:420px; height:420px; right:-140px; top:-140px;
  background: conic-gradient(from 210deg, rgba(13,110,253,.20), rgba(132,94,247,.16), rgba(13,110,253,.20));
  filter: blur(18px); opacity:.25;
}
.contact-us::after{
  width:360px; height:360px; left:-120px; bottom:-120px;
  background: radial-gradient(circle at 30% 30%, rgba(13,110,253,.14), rgba(132,94,247,.12), transparent 70%);
  filter: blur(10px); opacity:.25;
}
.contact-us .container,
.contact-us .row,
.contact-us .col-lg-12,
.contact-us .col-lg-7,
.contact-us .col-lg-5{ position:relative; z-index:1; }

/* =======================
   Map Card
======================= */
.contact-us #map{
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,.06);
  box-shadow: 0 8px 22px rgba(13,110,253,.10);
  background:#fff;
}
.contact-us #map iframe{
  display:block;
  width:100% !important;
  height: 360px;               /* more presence */
  border:0;
  filter: saturate(1.05) contrast(1.02);
}
/* grayscale hover (nice aesthetic, optional) */
.contact-us #map iframe{
  transition: filter .25s ease;
  filter: grayscale(.1) saturate(1.05) contrast(1.02);
}
.contact-us #map:hover iframe{
  filter: grayscale(0) saturate(1.08) contrast(1.04);
}
@media (max-width: 576px){
  .contact-us #map iframe{ height: 280px; }
}
/* soft overlay bottom for readability if labels show */
.contact-us #map::after{
  content:"";
  position:absolute; left:0; right:0; bottom:0; height:22%;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,.06) 100%);
  pointer-events:none;
}

/* =======================
   Contact Info Boxes
======================= */
.contact-us .contact-info-row{
  --gap: 18px; row-gap: var(--gap);
}
.contact-us .contact-info-box{
  display:flex; gap: 14px; align-items: center;
  background:#fff;
  border:1px solid rgba(0,0,0,.06);
  border-radius: 14px;
  padding: 14px 14px;
  box-shadow: 0 6px 18px rgba(13,110,253,.08);
  transition: transform .18s ease, box-shadow .22s ease, border-color .22s ease;
}
.contact-us .contact-info-box:hover{
  transform: translateY(-3px);
  border-color: #e6eeff;
  box-shadow: 0 12px 26px rgba(13,110,253,.14);
}
.contact-us .contact-info-box .icon{
  width: 48px; height: 48px; min-width:48px;
  display:grid; place-items:center;
  color:#fff; font-size: 20px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--ct-primary), var(--ct-accent));
  box-shadow: 0 8px 18px rgba(13,110,253,.18);
}
.contact-us .contact-info-box h4{
  margin:0 0 2px 0; font-size: 1rem; font-weight: 800; color: var(--ct-ink);
}
.contact-us .contact-info-box p{
  margin:0; color:#334155; font-weight:600;
}

/* =======================
   Contact Form
======================= */
.contact-us #contact{
  background:#fff;
  border:1px solid rgba(0,0,0,.06);
  border-radius: 16px;
  padding: clamp(16px, 3.2vw, 22px);
  box-shadow: 0 10px 26px rgba(13,110,253,.10);
}
.contact-us #contact .section-heading{
  margin-bottom: .8rem; text-align:center;
}
.contact-us #contact .section-heading h6{
  text-transform: uppercase; letter-spacing: .18em;
  font-weight: 800; color: var(--ct-muted); margin-bottom: .35rem;
}
.contact-us #contact .section-heading h4{
  font-weight: 800; color: var(--ct-ink); margin:0;
}
.contact-us #contact .section-heading h4 em{
  font-style: normal;
  background: linear-gradient(90deg, var(--ct-primary), var(--ct-accent));
  -webkit-background-clip: text; background-clip: text; color: transparent;
}

/* Labels & fields */
.contact-us #contact .form-group{
  display:flex; flex-direction: column;
  margin-bottom: 14px;
}
.contact-us #contact .form-group label{
  font-weight: 700; color: var(--ct-ink);
  margin-bottom: 6px; display:flex; align-items:center; gap: 8px;
}
.contact-us #contact .form-group label i{ color: var(--ct-primary); }

/* Inputs/textarea (no Bootstrap classes so target raw elements) */
.contact-us #contact input[type="text"],
.contact-us #contact input[type="email"],
.contact-us #contact textarea{
  width:100%;
  border:1px solid rgba(0,0,0,.12);
  border-radius: 12px;
  padding: 10px 12px;
  background:#fff;
  color:#111827;
  transition: border-color .15s ease, box-shadow .15s ease, background-color .15s ease;
}
.contact-us #contact input::placeholder,
.contact-us #contact textarea::placeholder{
  color:#8b97a5;
}
.contact-us #contact textarea{ min-height: 130px; resize: vertical; }

/* Focus & invalid states */
.contact-us #contact input:focus,
.contact-us #contact textarea:focus{
  outline:none;
  border-color: var(--ct-primary);
  box-shadow: 0 0 0 .22rem var(--ct-ring);
  background: #fcfdff;
}
.contact-us #contact input:invalid,
.contact-us #contact textarea:invalid{
  border-color: #ef4444;
}

/* Send button: premium gradient */
.contact-us #contact .main-gradient-button{
  display:inline-flex; align-items:center; justify-content:center;
  border:0; border-radius: 999px;
  padding: .7rem 1.1rem;
  font-weight: 800; letter-spacing: .2px;
  color:#fff; text-decoration:none;
  background: linear-gradient(90deg, var(--ct-primary), var(--ct-accent));
  box-shadow: 0 10px 22px rgba(13,110,253,.22);
  transition: transform .08s ease, box-shadow .18s ease, filter .18s ease;
}
.contact-us #contact .main-gradient-button:hover{
  filter: brightness(1.04);
  transform: translateY(-1px);
  box-shadow: 0 12px 28px rgba(13,110,253,.28);
}
.contact-us #contact .main-gradient-button:active{ transform: translateY(0); }

/* =======================
   Social Row
======================= */
.contact-us .social-row{
  background:#fff; border:1px solid rgba(0,0,0,.06);
  border-radius: 14px;
  box-shadow: 0 8px 22px rgba(13,110,253,.08);
}
.contact-us .social-row p{ color: var(--ct-ink); }

.contact-us .social-icons{
  list-style:none; display:flex; gap: 12px; align-items:center; justify-content:center;
  padding-left:0; margin:0;
}
.contact-us .social-icons li{ display:inline-flex; }

.contact-us .social-link{
  --size: 46px;
  width: var(--size); height: var(--size);
  display:grid; place-items:center;
  border-radius: 50%;
  color:#0b132b; background:#fff;
  border:1px solid rgba(0,0,0,.08);
  box-shadow: 0 8px 18px rgba(13,110,253,.10);
  transition: transform .1s ease, box-shadow .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
  text-decoration:none;
}

/* Brand colors (currentColor drives inline SVGs) */
.contact-us .social-link.facebook   { color:#1877f2; }
.contact-us .social-link.linkedin   { color:#0a66c2; }
.contact-us .social-link.youtube    { color:#ff0033; }
.contact-us .social-link.instagram  { color:#e1306c; }
.contact-us .social-link.whatsapp   { color:#25d366; }

.contact-us .social-link:hover{
  transform: translateY(-2px);
  background: currentColor;
  color: #fff;
  border-color: transparent;
  box-shadow: 0 12px 26px currentColor;
}
/* keep SVG fill white on hover */
.contact-us .social-link:hover svg{ fill:#fff !important; }

/* Copy line */
.contact-us .copyright{
  color:#64748b; margin: .6rem 0 0 0;
}

/* =======================
   Responsive
======================= */
@media (max-width: 991px){
  .contact-us{ padding: 40px 0; }
}
@media (max-width: 576px){
  .contact-us .contact-info-box{ padding: 12px; }
  .contact-us .social-link{ --size: 44px; }
}

/* =======================
   Optional Dark Mode
======================= */
@media (prefers-color-scheme: dark){
  :root{ --ct-ink:#e9edf5; --ct-muted:#9aa4b3; --ct-ring: rgba(102,163,255,.28); }
  .contact-us{ background: linear-gradient(135deg, #0b0e1a 0%, #0f1320 100%); }
  .contact-us #map,
  .contact-us .contact-info-box,
  .contact-us #contact,
  .contact-us .social-row{
    background:#0f1320; border-color: rgba(255,255,255,.10);
    box-shadow: 0 12px 26px rgba(0,0,0,.45);
  }
  .contact-us #contact input,
  .contact-us #contact textarea{
    background:#0b1020; color: #e9edf5;
    border-color: rgba(255,255,255,.14);
  }
  .contact-us #contact input::placeholder,
  .contact-us #contact textarea::placeholder{ color:#7b8694; }
  .contact-us .contact-info-box p{ color:#cfe3ff; }
  .contact-us .social-link{ background:#0b1020; border-color: rgba(255,255,255,.12); }
  .contact-us .copyright{ color:#9aa4b3; }
}

</style>