<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Error</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f8f8f8;
      color: #333;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
    }
    .error-box {
      background: #fff;
      padding: 40px 60px;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      text-align: center;
    }
    .error-box h1 {
      color: #e74c3c;
      font-size: 3rem;
      margin-bottom: 10px;
    }
    .error-box p {
      font-size: 1.1rem;
      margin-bottom: 20px;
    }
    a {
      background: #0fb513;
      color: #fff;
      padding: 10px 18px;
      border-radius: 5px;
      text-decoration: none;
    }
    a:hover {
      background: #000;
    }
  </style>
</head>
<body>
  <div class="error-box">
    <h1>⚠️ Oops!</h1>
    <p><%= message || "Something went wrong." %></p>
    <a href="/">Go Back Home</a>
  </div>
</body>
</html>
