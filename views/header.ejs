<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="PMLH Project Management Learning Hub">
  <meta name="author" content="PMLH">
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:100,200,300,400,500,600,700,800,900" rel="stylesheet">
  <title>PMLH Project Management Learning Hub</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/bootstrap.min`.css">
  <link rel="stylesheet" href="/css/font-awesome.css">
  <link rel="stylesheet" href="/css/contact-list-styles.css">
  <link rel="stylesheet" href="/css/main-header.css">
  <link rel="stylesheet" href="/css/coursera-style.css">
  <!-- Bootstrap core CSS -->
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <!-- Additional CSS Files -->
  <link rel="stylesheet" href="/assets/css/fontawesome.css">
  <link rel="stylesheet" href="/assets/css/templatemo-eduwell-style.css">
  <link rel="stylesheet" href="/assets/css/owl.css">
  <link rel="stylesheet" href="/assets/css/lightbox.css">
  <link rel="stylesheet" type="text/css"
    href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css" />
  <link rel="stylesheet" type="text/css"
    href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.querySelector(".menu-btn");
      const nav = document.querySelector(".nav-list");

      btn.addEventListener("click", () => {
        nav.classList.toggle("show");
      });
    });
  </script>
</head>
<body>
  <%- include('partials/alerts') %>
  <!-- ***** Header Area Start ***** -->
  <header class="header-area header-sticky" role="header">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <nav class="navbar navbar-expand-lg fixed-top">
            <div class="container-fluid">
              <!-- Logo -->
              <a class="navbar-brand" href="/">
                <img src="/assets/images/pmlh logo.png" alt="PMLH Logo" style="height:40px;">
              </a>

              <!-- Toggler button -->
              <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas"
                aria-controls="navbarOffcanvas" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>

              <!-- Offcanvas Menu -->
              <div class="offcanvas offcanvas-end" tabindex="-1" id="navbarOffcanvas"
                aria-labelledby="navbarOffcanvasLabel">
                <div class="offcanvas-header">
                  <h5 class="offcanvas-title" id="navbarOffcanvasLabel">Menu</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                  <!-- Nav links with icons -->
                  <ul class="navbar-nav justify-content-center flex-grow-1 pe-3">
                    <% if (typeof limitedHeader !=='undefined' && limitedHeader) { %>
                      <li class="nav-item">
                        <a class="nav-link active" href="/"><i class="fa fa-home me-1"></i> Home</a>
                      </li>
                      <% if (!user) { %>
                        <li class="nav-item">
                          <a class="nav-link" href="/user/login"><i class="fa fa-sign-in me-1"></i> Login</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="/contact-add"><i class="fa fa-user-plus me-1"></i> Register</a>
                        </li>
                      <% } else { %>
                        <li class="nav-item">
                          <a class="nav-link" href="/user/logout"><i class="fa fa-sign-out me-1"></i> Logout</a>
                        </li>
                      <% } %>
                      <% } else { %>
                        <li class="nav-item">
                          <a class="nav-link active" href="/"><i class="fa fa-home me-1"></i> Home</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="#services"><i class="fa fa-users me-1"></i> Association</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="#courses"><i class="fa fa-book me-1"></i> Courses</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="#testimonials"><i class="fa fa-comments me-1"></i> Testimonials</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="#webinar"><i class="fa fa-video-camera me-1"></i> Webinars</a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link" href="#contact-section"><i class="fa fa-envelope me-1"></i> Contact</a>
                        </li>
                        <li class="nav-item">
                          <a class="btn btn-warning text-dark fw-bold ms-2 px-3" href="certificate/verify"
                            style="border-radius: 6px;">
                            <i class="fa fa-check-circle me-1"></i> Verify Certificate
                          </a>
                        </li>


                        <% } %>
                  </ul>

                  <!-- User Profile / Login -->
                  <% if (!(typeof limitedHeader !=='undefined' && limitedHeader)) { %>
                    <div class="d-flex align-items-center">
                      <% if (user) { // normalize avatar path: prefer profileImage, then image/avatar, otherwise default
                        let avatarPath='/assets/images/default-user.png' ; if (user.profileImage) {
                        avatarPath='/uploads/' + user.profileImage; } else if (user.image) {
                        avatarPath=user.image.includes('/') ? user.image : ('/uploads/' + user.image); } else if
                        (user.avatar) { avatarPath=user.avatar.includes('/') ? user.avatar : ('/uploads/' +
                        user.avatar); } %>
                        <div class="me-2 text-end" style="line-height:1;">
                          <div class="fw-bold"><i class="fa fa-user-circle"></i>
                            <%= user.username || user.name || user.email %>
                          </div>
                          <div class="small text-muted">
                            <%= user.email || '' %>
                          </div>
                        </div>
                        <img src="<%= avatarPath %>" class="rounded-circle me-2"
                          style="width:35px;height:35px;object-fit:cover;">
                        <!-- Profile control: use a button with onclick to force a full navigation to /user/profile -->
                        <button type="button" onclick="window.location.href='/user/profile'"
                          class="btn btn-outline-secondary btn-sm me-2"><i class="fa fa-user"></i> Profile</button>
                        <a href="/user/logout" class="btn btn-outline-danger btn-sm"><i class="fa fa-sign-out"></i>
                          Logout</a>
                        <% } else { %>
                          <a href="/user/login" class="btn btn-outline-primary btn-sm px-4"><i
                              class="fa fa-sign-in"></i>
                            Login</a>
                          <% } %>
                    </div>
                    <% } %>
                </div>
              </div>
            </div>
          </nav>






        </div>
      </div>
    </div>
  </header>
  <style>
    /* Global offset to avoid content hiding under fixed header */
    :root { --header-offset: 72px; }
    body { padding-top: var(--header-offset); }
    @media (max-width: 992px) { :root { --header-offset: 64px; } }
    @media (max-width: 576px) { :root { --header-offset: 56px; } }
    /* 🔹 Navbar Base */
    .navbar {
      background: transparent !important;
      /* no background */
      padding: 8px 16px;
      transition: all 0.3s ease;
    }

    .navbar .nav-link {
      color: black !important;
      font-weight: 600;
      font-size: 17px;
      /* bigger font for desktop */
      display: flex;
      align-items: center;
      padding: 8px 14px;
      /* spacing around items */
      transition: color 0.2s ease;
    }

    .navbar .nav-link i {
      color: #333;
      font-size: 18px;
      /* larger icons */
      margin-right: 6px;
    }

    .navbar .nav-link:hover {
      color: #f5a623 !important;
    }

    .navbar .btn {
      font-size: 15px;
      padding: 6px 14px;
    }

    .navbar img.rounded-circle {
      width: 40px !important;
      height: 40px !important;
      object-fit: cover;
    }

    /* 🔹 Toggler */
    .navbar-toggler {
      border: none;
    }

    .navbar-toggler-icon {
      filter: invert(1);
      /* white hamburger */
    }

    /* 🔹 Offcanvas Menu */
    .offcanvas-header {
      border-bottom: 1px solid #eee;
    }

    .offcanvas-body {
      text-align: center;
    }

    .offcanvas-body .navbar-nav {
      gap: 10px;
    }

    /* 🔻 Medium & Small Screens */
    @media (max-width: 992px) {
      .navbar .nav-link {
        font-size: 15px;
        padding: 6px 10px;
      }

      .navbar .nav-link i {
        font-size: 16px;
      }

      .navbar img.rounded-circle {
        width: 32px !important;
        height: 32px !important;
      }

      .navbar .btn {
        font-size: 14px;
        padding: 5px 12px;
      }
    }

    /* 🔻 Extra Small Screens */
    @media (max-width: 576px) {
      .navbar .nav-link {
        font-size: 14px;
        padding: 5px 8px;
      }

      .navbar .nav-link i {
        font-size: 15px;
      }

      .navbar .btn {
        font-size: 13px;
        padding: 4px 10px;
      }
    }

    /* 🔹 Optional: Sticky Effect with Shadow */
    .header-sticky .navbar {
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
      background: #fff !important;
      /* subtle background when sticky */
    }
  </style>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.querySelector(".menu-btn");
      const nav = document.querySelector(".nav-list");

      btn.addEventListener("click", () => {
        nav.classList.toggle("show");
      });
    });
  </script>

  <!-- ***** Header Area End ***** -->