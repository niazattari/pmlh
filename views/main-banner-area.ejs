<!-- ***** Main Banner Area Start ***** -->

<section class="main-banner d-flex align-items-center bg-white" id="top">
  <div class="container">
    <div class="row align-items-center">

      <!-- Text Section -->
      <div class="col-lg-6 col-md-12 mb-4 mb-lg-0 text-center text-lg-start">
        <div class="header-text">
          <h6 class="text-uppercase text-muted mb-3">Welcome to</h6>
          <h1 class="display-5 fw-bold text-dark mb-3">
            Project Management <span class="text-primary">Learning Hub</span>
          </h1>
          <p class="lead text-secondary mb-4">
            The best place to master project management skills and boost your career.
          </p>
          <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
            <% if (!locals.user) { %>
              <a href="#contact-section" class="btn btn-outline-primary btn-lg px-4">
                <i class="fas fa-users me-2"></i> Join Us Now
              </a>
              <a href="/contact-add" class="btn btn-outline-primary btn-lg px-4">
                <i class="fas fa-user-plus me-2"></i> Register
              </a>
            <% } else { %>
              <div class="welcome-greeting text-start">
                <h3 class="mb-1">Welcome back, <span class="text-primary"><%= locals.user.username || locals.user.name || locals.user.email %></span></h3>
                <p class="lead text-muted mb-0"><%= locals.user.email || '' %></p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Fixed Single Image Section -->
      <div class="col-lg-6 col-md-12 d-flex justify-content-center">
        <!-- show only the image (no border/padding) -->
        <div class="image-box text-center">
          <img src="/assets/images/pmlhdesign2.png" class="fixed-banner-img img-fluid" alt="Banner">
        </div>
      </div>

    </div>
  </div>
</section>
<!-- ***** Main Banner Area End ***** -->

<style>
  
/* ================================
   PMLH - Hero Refresh (CSS only)
   Scoped to .main-banner
=================================== */
:root{
  --pmlh-primary: #0d6efd;   /* Bootstrap primary */
  --pmlh-accent:  #845ef7;   /* Educational accent (purple) */
  --pmlh-ink:     #0b132b;   /* Headline color */
  --pmlh-muted:   #6c757d;   /* Muted text */
  --pmlh-bg:      #f7f9ff;   /* Soft page backdrop */
}

/* Main banner full height – visual uplift */
.main-banner{
  min-height: 100vh;
  width: 100%;
  padding-top: 100px;        /* navbar offset */
  padding-bottom: 60px;
  border-bottom: 1px solid #eef2ff;
  box-sizing: border-box;
  position: relative;
  overflow: clip;
  background:
    radial-gradient(900px 500px at 85% -10%, rgba(13,110,253,.08) 0%, transparent 60%),
    radial-gradient(800px 400px at -10% 110%, rgba(132,94,247,.08) 0%, transparent 70%),
    linear-gradient(180deg, #ffffff 0%, var(--pmlh-bg) 100%);
}

/* Decorative educational “energy” blobs */
.main-banner::before,
.main-banner::after{
  content:"";
  position:absolute;
  border-radius: 50%;
  z-index: 0;
}
.main-banner::before{
  right: -120px; top: -120px;
  width: 420px; height: 420px;
  background: conic-gradient(from 210deg at 50% 50%,
              rgba(13,110,253,.22),
              rgba(132,94,247,.18),
              rgba(13,110,253,.22));
  filter: blur(18px) saturate(1.1);
  opacity: .28;
}
.main-banner::after{
  left: -140px; bottom: -140px;
  width: 360px; height: 360px;
  background: radial-gradient(circle at 30% 30%,
              rgba(13,110,253,.15),
              rgba(132,94,247,.12),
              transparent 70%);
  filter: blur(12px);
  opacity: .25;
}

/* Keep your content above the decorative layers */
.main-banner .container{ position: relative; z-index: 1; }

/* ---------- Typography & Copy ---------- */
.header-text h6{
  text-transform: uppercase;
  letter-spacing: .14em;
  font-weight: 700;
  color: var(--pmlh-muted) !important;
  margin-bottom: .65rem !important;
}

.header-text h1{
  color: var(--pmlh-ink);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: .6rem !important;
}

/* Gradient emphasis for “Learning Hub” */
.header-text h1 .text-primary{
  background: linear-gradient(90deg, var(--pmlh-primary), var(--pmlh-accent));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.header-text p{
  color: #475569 !important; /* slightly stronger than .text-secondary for readability */
}

/* ---------- Buttons (education vibe) ---------- */
.main-banner .btn{
  border-radius: 12px;
  padding: .65rem 1.1rem;
  font-weight: 700;
  letter-spacing: .2px;
  transition: transform .08s ease, box-shadow .18s ease, filter .18s ease;
}
.main-banner .btn:active{ transform: translateY(1px); }

.main-banner .btn-outline-primary{
  border-width: 2px;
  color: var(--pmlh-primary);
  background: linear-gradient(180deg, #ffffff, #f6f9ff);
}
.main-banner .btn-outline-primary:hover{
  background: var(--pmlh-primary);
  color: #fff;
  box-shadow: 0 10px 22px rgba(13,110,253,.25);
  transform: translateY(-1px);
}

/* Maintain spacing for the button group */
.main-banner .gap-3{ gap: 0.9rem !important; }

/* ---------- Image polish (only the image shows) ---------- */
.image-box{
  max-width: 100%;
  height: auto;
  display: flex; align-items: center; justify-content: center;
  background: transparent; padding: 0; box-shadow: none; border-radius: 0;
  position: relative;
}
.fixed-banner-img{
  max-height: 360px; /* slightly larger for hero presence */
  width: 100%;
  object-fit: contain;
  border-radius: 0;
  filter: drop-shadow(0 24px 44px rgba(13,110,253,.18));
  animation: pmlhFloat 6s ease-in-out infinite;
}
@keyframes pmlhFloat{
  0%,100%{ transform: translateY(0) }
  50%{ transform: translateY(-8px) }
}
/* Soft “stage” shadow underneath image */
.image-box::after{
  content:"";
  position:absolute; inset: auto 0 -16px 0; margin: auto;
  width: 70%; height: 14px;
  background: radial-gradient(closest-side, rgba(13,110,253,.16), transparent 68%);
  filter: blur(3px);
  border-radius: 50%;
}

/* ---------- Subtle dotted grid pattern (education/structure) ---------- */
.main-banner .row::after{
  content:"";
  position:absolute; right: clamp(6px, 2vw, 18px); top: clamp(6px, 2vw, 18px);
  width: 140px; height: 140px; opacity: .16; z-index: 0;
  background-image:
    radial-gradient(circle at 1px 1px, rgba(13,110,253,.6) 1px, transparent 0);
  background-size: 14px 14px;
  border-radius: 12px;
}

/* ---------- Responsive tweaks & spacing ---------- */
@media (max-width: 1200px){
  .fixed-banner-img{ max-height: 340px; }
}
@media (max-width: 991px){
  .header-text h1{ font-size: 2rem; line-height: 1.28; }
  .fixed-banner-img{ max-height: 300px; }
  .main-banner{ padding-top: 90px; padding-bottom: 52px; }
}
@media (max-width: 576px){
  .header-text h1{ font-size: 1.65rem; }
  .header-text p{ font-size: .95rem; }
  .fixed-banner-img{ max-height: 230px; }
  .main-banner .btn{ font-size: .92rem; padding: .55rem 1rem; }
}

/* ===========================
   Optional: Right-side Quick Links
   (Requires tiny HTML snippet below)
=========================== */
.pmlh-quick-links{
  position: fixed;
  top: 50%; right: 18px;
  transform: translateY(-50%);
  display: flex; flex-direction: column; gap: .55rem;
  z-index: 1040;
}
.pmlh-quick-links a{
  display: flex; align-items: center; gap: .5rem;
  padding: .5rem .7rem;
  border-radius: 999px;
  text-decoration: none;
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(0,0,0,.08);
  color: #0b132b;
  font-weight: 600; font-size: .92rem;
  box-shadow: 0 6px 16px rgba(13,110,253,.15);
  transition: transform .15s ease, box-shadow .18s ease, background .18s ease;
}
.pmlh-quick-links a:hover{
  transform: translateX(-2px);
  box-shadow: 0 10px 22px rgba(13,110,253,.22);
}
.pmlh-quick-links a .dot{
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--pmlh-primary);
  box-shadow: 0 0 0 3px rgba(13,110,253,.18);
}

/* Mobile: move links to bottom-right as a compact row */
@media (max-width: 991px){
  .pmlh-quick-links{
    top: auto; bottom: 18px; right: 14px; transform: none;
    flex-direction: row; gap: .45rem;
  }
  .pmlh-quick-links a{ padding: .45rem .6rem; font-size: .88rem; }
}

</style>
