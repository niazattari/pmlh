<%- include('header') %>
<% if (!user) { %>
  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card text-center p-4">
          <div class="card-body">
            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-warning"><%= error %></div>
            <% } %>
            <h4 class="mb-3">Please sign in to view your profile</h4>
            <p class="mb-4">You can view and manage your profile information and course registrations after logging in.</p>
            <a href="/user/login" class="btn btn-primary me-2">Login</a>
            <a href="/contact-add" class="btn btn-outline-secondary">Create Account</a>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="container my-5">
    <div class="row">
      <div class="col-md-4">
        <div class="card shadow-sm">
          <div class="card-body text-center">
            <% 
              // Normalize avatar path: uploaded files are saved as filename in /uploads
              let avatarPath = 'assets/images/default-user.png';
              if (user.profileImage) {
                avatarPath = '/uploads/' + user.profileImage;
              } else if (user.image) {
                // if image looks like a filename, prefix uploads; otherwise use as-is
                avatarPath = user.image.includes('/') ? user.image : '/uploads/' + user.image;
              } else if (user.avatar) {
                avatarPath = user.avatar.includes('/') ? user.avatar : '/uploads/' + user.avatar;
              }
            %>
            <img src="<%= avatarPath %>" alt="Profile" class="img-fluid rounded-circle mb-3" style="width:140px;height:140px;object-fit:cover;">
            <h3 class="mb-1"><%= user.username || user.name || user.email %></h3>
            <p class="text-muted mb-2"><i class="fa fa-envelope me-1"></i> <%= user.email || 'N/A' %></p>
            <div class="d-grid gap-2">
              <a href="/user/profile" class="btn btn-outline-primary">View Profile</a>
              <a href="/user/logout" class="btn btn-outline-danger">Logout</a>
            </div>
          </div>
        </div>
        <div class="card mt-3">
          <div class="card-body">
            <h6>Personal Info</h6>
            <ul class="list-unstyled small">
              <% if (user.contactNo) { %><li><strong>Phone:</strong> <%= user.contactNo %></li><% } %>
              <% if (user.fatherName) { %><li><strong>Father's Name:</strong> <%= user.fatherName %></li><% } %>
              <% if (user.qualificaiton) { %><li><strong>Qualification:</strong> <%= user.qualificaiton %></li><% } %>
              <% if (user.country) { %><li><strong>Country:</strong> <%= user.country %></li><% } %>
              <% if (user.address) { %><li><strong>Address:</strong> <%= user.address %></li><% } %>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card shadow-sm">
          <div class="card-body">
            <h4 class="mb-3">Your Course Registrations</h4>

            <% // show notice if any registration is pending review %>
            <% const hasPending = registrations && registrations.some(r => r.status === 'pending'); %>
            <% if (hasPending) { %>
              <div class="alert alert-info">One or more of your registrations are currently pending review by our admin team. Statuses are usually updated within 24 hours.</div>
            <% } %>

            <% if (registrations && registrations.length) { %>
              <div class="row g-3">
                <% registrations.forEach(function(r){ %>
                  <div class="col-md-12">
                    <div class="card p-3">
                      <div class="d-flex align-items-center">
                        <% let courseImagePath = 'assets/images/course-placeholder.png'; %>
                        <% if (r.course && r.course.image) { %>
                          <% courseImagePath = r.course.image.includes('/') ? r.course.image : ('/uploads/' + r.course.image); %>
                        <% } %>
                        <img src="<%= courseImagePath %>" alt="Course" style="width:90px;height:60px;object-fit:cover;border-radius:6px;" class="me-3">
                        <div class="flex-grow-1">
                          <h5 class="mb-1"><%= r.course ? r.course.title : 'Unknown Course' %></h5>
                          <div class="small text-muted mb-1">Registered on: <%= new Date(r.registrationDate).toLocaleString() %></div>
                          <div class="small">Payment: <strong><%= r.paymentMethod || 'N/A' %></strong> &nbsp; | &nbsp; Status: <span class="badge bg-<%= (r.status==='confirmed' || r.status==='completed') ? 'success' : r.status==='pending' ? 'warning' : 'secondary' %>"><%= r.status %></span></div>
                        </div>
                        <div class="text-end">
                          <% if (r.paymentProof) { %>
                            <a href="/uploads/<%= r.paymentProof %>" class="btn btn-sm btn-outline-primary" target="_blank">View Proof</a>
                          <% } %>
                          <% if (r.certificate) { %>
                            <a href="/uploads/<%= r.certificate %>" class="btn btn-sm btn-success ms-2" target="_blank" download>Download Certificate</a>
                            <% if (r.certificateNumber) { %>
                              <a href="/certificate/verify?certificateNumber=<%= encodeURIComponent(r.certificateNumber) %>" class="btn btn-sm btn-outline-primary ms-2" target="_blank">Verify</a>
                            <% } %>
                          <% } %>
                          <% if (r.courseContent) { %>
                            <a href="/uploads/<%= r.courseContent %>" class="btn btn-sm btn-primary ms-2" target="_blank" download>Download Course Content</a>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted">You have not registered for any courses yet.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>

<%- include('footer') %>

<style>
  
/* =========================================
   Main Theme (Profile & Registrations)
   Professional + Catchy + Consistent
   Works with existing Bootstrap markup
   ========================================= */

:root {
  --brand: #0d6efd;             /* primary */
  --brand-dark: #0b5ed7;
  --accent: #20c997;            /* teal accent */
  --text: #1f2937;              /* slate-800 */
  --muted: #6b7280;             /* slate-500 */
  --bg: #f7f9fc;
  --surface: #ffffff;
  --border: #e5e7eb;            /* slate-200 */
  --radius: 18px;
  --shadow: 0 12px 32px rgba(16,24,40,.12);
}

/* ---------- Page background & type ---------- */
body {
  color: var(--text);
  background:
    radial-gradient(1200px 600px at 8% -10%, rgba(13,110,253,.06), transparent 40%),
    radial-gradient(900px 480px at 95% -10%, rgba(32,201,151,.06), transparent 35%),
    var(--bg);
  -webkit-font-smoothing: antialiased;
  font-smooth: antialiased;
}

.container.my-5 {
  max-width: 1140px;
}

/* ---------- Cards (global) ---------- */
.card {
  border-radius: var(--radius);
  border: 1px solid var(--border);
  background: linear-gradient(180deg, #fff, #fbfbfc 55%, #f8fafc);
  box-shadow: var(--shadow);
}
.card .card-body {
  padding: 1.25rem 1.25rem;
}

/* subtle section headings with accent underline */
.card h3, .card h4, .card h5, .card h6 {
  font-weight: 700;
  letter-spacing: .2px;
  margin-bottom: .75rem;
  position: relative;
}
.card h4::after, .card h3::after {
  content: "";
  display: block;
  width: 64px;
  height: 3px;
  border-radius: 2px;
  margin-top: .35rem;
  background: linear-gradient(90deg, var(--brand), var(--accent));
}

/* ---------- Alerts ---------- */
.alert-warning {
  border-radius: 12px;
  border: 1px solid #fde68a;
  background: #fffbeb;
  color: #7c2d12;
}
.alert-info {
  border-radius: 12px;
  border: 1px solid #bae6fd;
  background: #eff6ff;
  color: #0c4a6e;
}

/* ---------- Buttons (harmonized) ---------- */
.btn {
  border-radius: 12px;
  font-weight: 600;
  letter-spacing: .2px;
  transition: transform .08s ease, box-shadow .2s ease, filter .2s ease;
}

.btn-primary {
  border: none;
  background: linear-gradient(180deg, var(--brand), var(--brand-dark));
  box-shadow: 0 10px 24px rgba(13,110,253,.22);
}
.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 14px 30px rgba(13,110,253,.28); }

.btn-outline-secondary {
  border: 1px solid var(--border);
  color: #334155;
  background: #fff;
}
.btn-outline-secondary:hover { filter: brightness(1.03); }

.btn-outline-primary {
  border: 1px solid var(--brand);
  color: var(--brand);
  background: transparent;
}
.btn-outline-primary:hover { background: rgba(13,110,253,.08); }

.btn-outline-danger {
  border: 1px solid #ef4444;
  color: #b91c1c;
  background: transparent;
}
.btn-outline-danger:hover { background: rgba(239,68,68,.08); }

.btn-success {
  border: none;
  background: linear-gradient(180deg, var(--accent), #18b892);
  box-shadow: 0 10px 24px rgba(32,201,151,.22);
}
.btn-success:hover { transform: translateY(-1px); box-shadow: 0 14px 30px rgba(32,201,151,.26); }

/* ---------- Not signed-in hero card ---------- */
.card.text-center.p-4 {
  padding: 2rem !important;
}
.card.text-center.p-4 h4 {
  margin-bottom: .5rem;
}
.card.text-center.p-4 p {
  color: var(--muted);
  margin-bottom: 1rem;
}
.card.text-center.p-4 .btn {
  min-width: 140px;
}

/* ---------- Profile panel ---------- */
.col-md-4 .card.shadow-sm:first-of-type {
  position: sticky;
  top: 1rem; /* stays visible while scrolling registrations */
}

.img-fluid.rounded-circle {
  /* ring effect around avatar */
  box-shadow: 0 0 0 4px #fff, 0 0 0 6px rgba(13,110,253,.15);
}

.text-muted i.fa {
  color: var(--brand);
}

/* personal info list */
.card .list-unstyled.small li {
  padding: .35rem 0;
  border-bottom: 1px dashed var(--border);
}
.card .list-unstyled.small li:last-child {
  border-bottom: none;
}
.card .list-unstyled.small li strong {
  display: inline-block;
  min-width: 160px;
  color: #111827;
}

/* ---------- Registrations list ---------- */
.row.g-3 .card.p-3 {
  border-radius: 16px;
  border: 1px solid var(--border);
  background: #fff;
  transition: transform .08s ease, box-shadow .2s ease, border-color .2s ease;
  /* accent stripe on the left */
  border-left: 5px solid #e2e8f0;
}
.row.g-3 .card.p-3:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 28px rgba(16,24,40,.12);
  border-color: #d9dee8;
}

.row.g-3 .card.p-3 .d-flex.align-items-center {
  gap: .75rem;
}

/* small meta text */
.small.text-muted {
  color: var(--muted) !important;
}

/* badge styling */
.badge.bg-success {
  background-color: #22c55e !important;
}
.badge.bg-warning {
  background-color: #f59e0b !important;
  color: #111827;
}
.badge.bg-secondary {
  background-color: #64748b !important;
}

/* Optional progressive enhancement: change left accent by status (modern browsers) */
.card.p-3:has(.badge.bg-success) { border-left-color: #22c55e; }
.card.p-3:has(.badge.bg-warning) { border-left-color: #f59e0b; }
.card.p-3:has(.badge.bg-secondary) { border-left-color: #64748b; }

/* action buttons on the right */
.text-end .btn.btn-sm {
  border-radius: 10px;
  padding: .35rem .6rem;
}

/* course thumbnail */
.me-3 + .flex-grow-1 h5 {
  margin-bottom: .25rem;
}

/* ---------- Links & focus ---------- */
a {
  color: var(--brand);
  text-decoration: none;
}
a:hover { text-decoration: underline; }

a:focus, button:focus {
  outline: 2px solid rgba(13,110,253,.3);
  outline-offset: 2px;
}

/* ---------- Responsive ---------- */
@media (max-width: 768px) {
  .container.my-5 { padding-left: .75rem; padding-right: .75rem; }
  .card .card-body { padding: 1rem; }
  .row.g-3 .card.p-3 { padding: .9rem !important; }
}

/* ---------- Print (for saving views neatly) ---------- */
@media print {
  body { background: #fff !important; }
  header, nav, footer, .alert, .btn { display: none !important; }
  .card { box-shadow: none !important; border-color: #ddd !important; }
}

/* ---------- Dark mode ---------- */
@media (prefers-color-scheme: dark) {
  :root {
    --text: #e5e7eb;
    --muted: #9ca3af;
    --bg: #0b1220;
    --surface: #0f172a;
    --border: #1f2937;
    --shadow: 0 12px 32px rgba(0,0,0,.38);
  }
  body {
    background:
      radial-gradient(1200px 600px at 8% -10%, rgba(13,110,253,.18), transparent 40%),
      radial-gradient(900px 480px at 95% -10%, rgba(32,201,151,.18), transparent 35%),
      var(--bg);
  }
  .card {
    background: linear-gradient(180deg, var(--surface), #0d1730 55%, #0a1328);
    border-color: var(--border);
  }
  .alert-warning { background: #332c10; border-color: #fde68a33; color: #fef08a; }
  .alert-info    { background: #102032; border-color: #bae6fd33; color: #bae6fd; }
  .btn-outline-secondary { background: transparent; color: #d1d5db; border-color: var(--border); }
  .img-fluid.rounded-circle { box-shadow: 0 0 0 4px #0b1324, 0 0 0 6px rgba(13,110,253,.35); }
}

</style>